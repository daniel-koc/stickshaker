{
  "name": "stickshaker",
  "version": "0.1.0",
  "description": "A systems-grade browser-agent runtime.",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.6"
  },
  "bin": {
    "stickshaker": "dist/cli.js"
  },
  "scripts": {
    "stickshaker": "tsx src/cli.ts",
    "demo": "tsx scripts/generate-demo.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.tests.json",
    "test": "tsx --test tests/guardrails.test.ts tests/graders.test.ts tests/observe.test.ts tests/memory.test.ts tests/llm-ollama.test.ts tests/router.test.ts tests/view.test.ts tests/browser.test.ts tests/mcp.test.ts tests/agent.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "commander": "^14.0.0",
    "playwright": "^1.56.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
